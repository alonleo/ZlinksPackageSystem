<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Stat Cards (2x2) -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Row="0" Grid.Column="0" Margin="8" Padding="16"
                                 Background="{StaticResource MaterialDesign.Brush.Primary}"
                                 UniformCornerRadius="10">
                <StackPanel>
                    <TextBlock Text="游戏数量" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding GameCount}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="0" Grid.Column="1" Margin="8" Padding="16"
                                 Background="{StaticResource MaterialDesign.Brush.Secondary}"
                                 UniformCornerRadius="10">
                <StackPanel>
                    <TextBlock Text="产品数量" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding ProductCount}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="8" Padding="16"
                                 Background="#FFE6A23C"
                                 UniformCornerRadius="10">
                <StackPanel>
                    <TextBlock Text="测试数量" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding TestCount}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Grid.Column="1" Margin="8" Padding="16"
                                 Background="#FF52C41A"
                                 UniformCornerRadius="10">
                <StackPanel>
                    <TextBlock Text="通知" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding NotificationCount}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Foreground="#B3FFFFFF" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <Run Text="{Binding UnreadCount}"/><Run Text=" 条未读"/>
                    </TextBlock>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Notification List -->
        <materialDesign:Card Grid.Row="1" Margin="8,16,8,0" Padding="16" UniformCornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="最新通知" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                <ListView Grid.Row="1" ItemsSource="{Binding Notifications}"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#FF52C41A"
                                         Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock Grid.Column="1" Text="{Binding Message}"
                                           FontSize="13" VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>

                                <TextBlock Grid.Column="2" Text="{Binding Time, StringFormat='{}{0:HH:mm}'}"
                                           FontSize="11" Foreground="#99FFFFFF"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>