<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ZlinksPackageSystem.Desktop.ViewModels"
             xmlns:m="clr-namespace:ZlinksPackageSystem.Desktop.Models"
             x:Class="ZlinksPackageSystem.Desktop.Views.ParameterView"
             x:DataType="vm:ParameterViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#FF1976D2" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="DataGridRow:pointerover DataGridCell">
            <Setter Property="Background" Value="#0DFFFFFF" />
        </Style>
        <Style Selector="DataGridRow:selected DataGridCell">
            <Setter Property="Background" Value="#1A1976D2" />
        </Style>
    </UserControl.Styles>

    <Panel>

        <!-- 空状态：无平台 -->
        <Border IsVisible="{Binding IsPlatformsEmpty}"
                Background="Transparent"
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📋 暂无平台数据"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundPrimary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding EmptyStateMessage}"
                           Foreground="{DynamicResource ForegroundSecondary}"
                           HorizontalAlignment="Center" />
                <Button Content="↻ 重新加载"
                        Width="120" Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding LoadPlatformsCommand}" />
            </StackPanel>
        </Border>

        <!-- 主体 -->
        <Grid IsVisible="{Binding HasPlatforms}" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- TabControl -->
            <TabControl Grid.Row="0"
                        ItemsSource="{Binding Platforms}"
                        SelectedItem="{Binding SelectedPlatform, Mode=TwoWay}"
                        Margin="0,0,0,12">
                <TabControl.ItemTemplate>
                    <DataTemplate DataType="m:Platform">
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                            <TextBlock Text="{Binding PlatformName}" VerticalAlignment="Center" />
                            <Border IsVisible="{Binding !IsMapped}"
                                    Background="#FFF56C6C" CornerRadius="3"
                                    Padding="6,1" VerticalAlignment="Center">
                                <TextBlock Text="未对接" FontSize="10" Foreground="{DynamicResource ForegroundPrimary}" />
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>

            <!-- 顶部工具栏 -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
                <TextBox Grid.Column="0" Text="{Binding SearchText}"
                         Watermark="🔍 搜索参数（当前仅 UI 占位）"
                         IsEnabled="False" />
                <Button Grid.Column="1" Content="搜索" Width="80" Margin="8,0,0,0"
                        Command="{Binding SearchCommand}"
                        IsEnabled="{Binding IsCurrentPlatformMapped}" />
                <Button Grid.Column="2" Content="＋ 新增参数" Width="110" Margin="8,0,0,0"
                        BorderBrush="#FF1976D2" Foreground="#FF1976D2"
                        IsEnabled="{Binding IsCurrentPlatformMapped}"
                        Command="{Binding OpenAddDialogCommand}" />
            </Grid>

            <!-- DataGrid：列由代码后台动态生成 -->
            <Panel Grid.Row="2">
                <DataGrid x:Name="ParamsDataGrid"
                          IsVisible="{Binding IsCurrentPlatformMapped}"
                          ItemsSource="{Binding Params}"
                          SelectedItem="{Binding SelectedParam, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="操作" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="m:AdParam">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Content="✏ 编辑" FontSize="11"
                                                BorderBrush="#FF1976D2" Foreground="#FF1976D2"
                                                Command="{Binding $parent[UserControl].((vm:ParameterViewModel)DataContext).OpenEditDialogCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="🗑 删除" FontSize="11"
                                                BorderBrush="#FFF56C6C" Foreground="#FFF56C6C"
                                                Command="{Binding $parent[UserControl].((vm:ParameterViewModel)DataContext).DeleteProductCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 未映射占位 -->
                <Border IsVisible="{Binding !IsCurrentPlatformMapped}"
                        Background="Transparent"
                        VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚠ 当前平台暂未对接参数类型"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundPrimary}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Foreground="{DynamicResource ForegroundSecondary}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="600">
                            <Run Text="平台 " /><Run Text="{Binding SelectedPlatform.PlatformName, Mode=OneWay}" /><Run Text="（编码：" /><Run Text="{Binding SelectedPlatform.PlatformCode, Mode=OneWay}" /><Run Text="）未对接参数类型。" />
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource ForegroundSecondary}" FontSize="12"
                                   HorizontalAlignment="Center"
                                   Text="请在后台「平台管理」中将其 platformCode 设置为 honor / vivo / huawei 之一" />
                    </StackPanel>
                </Border>
            </Panel>

            <!-- 分页 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,12,0,0">
                <Button Content="◀ 上一页" Command="{Binding PreviousPageCommand}" Width="90"
                        IsEnabled="{Binding IsCurrentPlatformMapped}" />
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundPrimary}" FontSize="14" />
                <TextBlock Text="/" VerticalAlignment="Center" Foreground="#66FFFFFF" FontSize="14" />
                <TextBlock Text="{Binding TotalCount}" VerticalAlignment="Center" Foreground="#66FFFFFF" FontSize="14" />
                <Button Content="下一页 ▶" Command="{Binding NextPageCommand}" Width="90"
                        IsEnabled="{Binding IsCurrentPlatformMapped}" />
            </StackPanel>
        </Grid>

        <!-- 编辑覆盖层 -->
        <Border IsVisible="{Binding IsEditing}"
                Background="#80000000"
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="560" Padding="24" CornerRadius="12"
                    Background="{DynamicResource WindowBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding EditTitle}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ForegroundPrimary}" />

                    <ScrollViewer MaxHeight="540" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EditFieldRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="m:FieldEditRow">
                                    <Grid ColumnDefinitions="100,*" Margin="0,4">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Foreground="#CCFFFFFF"
                                                   VerticalAlignment="Center" />
                                        <Panel Grid.Column="1">
                                            <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                     Watermark="{Binding Placeholder}"
                                                     IsVisible="{Binding IsText}" />
                                            <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                     Watermark="{Binding Placeholder}"
                                                     AcceptsReturn="True" Height="60"
                                                     IsVisible="{Binding IsMultiLine}" />
                                            <ComboBox ItemsSource="{Binding Options}"
                                                      SelectedItem="{Binding Value, Mode=TwoWay}"
                                                      HorizontalAlignment="Stretch"
                                                      IsVisible="{Binding IsCombo}" />
                                        </Panel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,8,0,0">
                        <Button Content="取消" Width="80" Command="{Binding CancelEditCommand}" />
                        <Button Content="保存" Width="80"
                                Background="#FF1976D2" BorderBrush="#FF1976D2" Foreground="{DynamicResource ForegroundPrimary}"
                                Command="{Binding SaveProductCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

    </Panel>
</UserControl>