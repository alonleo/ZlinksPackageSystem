<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ZlinksPackageSystem.Desktop.ViewModels"
             xmlns:m="clr-namespace:ZlinksPackageSystem.Desktop.Models"
             x:Class="ZlinksPackageSystem.Desktop.Views.GameListView"
             x:DataType="vm:GameListViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#FF1976D2" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="DataGridRow:pointerover DataGridCell">
            <Setter Property="Background" Value="#0DFFFFFF" />
        </Style>
        <Style Selector="DataGridRow:selected DataGridCell">
            <Setter Property="Background" Value="#1A1976D2" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- 空状态：无数据 / 后端不可达 -->
        <Border IsVisible="{Binding IsGamesEmpty}"
                Background="Transparent"
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🎮 暂无游戏数据"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundPrimary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding EmptyStateMessage}"
                           Foreground="{DynamicResource ForegroundSecondary}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500" />
                <Button Content="↻ 重新加载"
                        Width="120" Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding LoadGamesCommand}" />
            </StackPanel>
        </Border>

        <!-- 主体 -->
        <Grid IsVisible="{Binding HasGames}" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16" ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="🎮 游戏列表" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundPrimary}" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="↻ 刷新"
                        Command="{Binding LoadGamesCommand}"
                        Width="80" Margin="0,0,8,0"
                        VerticalAlignment="Center" />
                <Button Grid.Column="3" Content="＋ 新增游戏"
                        Command="{Binding OpenAddDialogCommand}"
                        Width="110"
                        BorderBrush="#FF1976D2" Foreground="#FF1976D2"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Search Bar -->
            <Border Grid.Row="1" Background="Transparent" Padding="0" Margin="0,0,0,16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding SearchText}"
                             Watermark="🔍 搜索游戏名称..."
                             HorizontalAlignment="Stretch"
                             Margin="0,0,10,0" />
                    <Button Grid.Column="1" Content="搜索"
                            Command="{Binding SearchCommand}"
                            Width="80" />
                </Grid>
            </Border>

            <!-- Data Grid -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Games}"
                      SelectedItem="{Binding SelectedGame}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                    <DataGridTextColumn Header="游戏名称" Binding="{Binding GameName}" Width="3*" />
                    <DataGridTextColumn Header="游戏方向" Binding="{Binding GameDirection}" Width="2*" />
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="2*" />
                    <DataGridTextColumn Header="负责人" Binding="{Binding Manager}" Width="1.5*" />
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="1.5*" />
                    <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="1*" />
                    <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="2.5*" />
                    <DataGridTemplateColumn Header="操作" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="m:Game">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Button Content="✏ 编辑" FontSize="11"
                                            BorderBrush="#FF1976D2" Foreground="#FF1976D2"
                                            Command="{Binding $parent[UserControl].((vm:GameListViewModel)DataContext).OpenEditDialogCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="🗑 删除" FontSize="11"
                                            Command="{Binding $parent[UserControl].((vm:GameListViewModel)DataContext).DeleteGameCommand}"
                                            CommandParameter="{Binding}"
                                            BorderBrush="#FFF56C6C"
                                            Foreground="#FFF56C6C" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Pagination -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0" Spacing="10">
                <Button Content="◀ 上一页"
                        Command="{Binding PreviousPageCommand}"
                        Width="90" />
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center"
                           Foreground="{DynamicResource ForegroundPrimary}" FontSize="14" />
                <TextBlock Text="/" VerticalAlignment="Center"
                           Foreground="#66FFFFFF" FontSize="14" />
                <TextBlock Text="{Binding TotalCount}" VerticalAlignment="Center"
                           Foreground="#66FFFFFF" FontSize="14" />
                <Button Content="下一页 ▶"
                        Command="{Binding NextPageCommand}"
                        Width="90" />
            </StackPanel>
        </Grid>

        <!-- Edit Overlay -->
        <Border IsVisible="{Binding IsEditing}"
                Background="#80000000"
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="440" Padding="24" CornerRadius="12"
                    Background="{DynamicResource WindowBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="游戏信息" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundPrimary}" />

                    <TextBox Text="{Binding EditGameName}" Watermark="🎮 游戏名称" />
                    <Grid ColumnDefinitions="*,*">
                        <TextBox Grid.Column="0" Text="{Binding EditGameDirection}"
                                 Watermark="📂 游戏方向" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding EditSource}"
                                 Watermark="📦 来源" Margin="6,0,0,0" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*">
                        <TextBox Grid.Column="0" Text="{Binding EditManager}"
                                 Watermark="👤 负责人" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding EditStatus}"
                                 Watermark="📊 状态" Margin="6,0,0,0" />
                    </Grid>
                    <TextBox Text="{Binding EditPriority}" Watermark="⭐ 优先级" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                Margin="0,8,0,0" Spacing="10">
                        <Button Content="取消" Width="80"
                                Command="{Binding CancelEditCommand}" />
                        <Button Content="保存" Width="80"
                                Background="#FF1976D2" BorderBrush="#FF1976D2"
                                Foreground="{DynamicResource ForegroundPrimary}"
                                Command="{Binding SaveGameCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>
