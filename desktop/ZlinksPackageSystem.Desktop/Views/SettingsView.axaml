<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ZlinksPackageSystem.Desktop.Views.SettingsView">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="600">

            <!-- 🎨 主题设置 -->
            <Border Margin="0,0,0,16" Padding="20" CornerRadius="8"
                    Background="Transparent"
                    BorderBrush="#661976D2" BorderThickness="0,0,0,1">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                        <TextBlock Grid.Column="0" Text="🎨" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="主题设置" FontSize="16" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Margin="10,0,0,0">
                        <RadioButton GroupName="Theme" Content="☀️ 浅色模式"
                                     IsChecked="{Binding IsDarkTheme, Converter={StaticResource BooleanInverseConverter}}"
                                     Margin="0,0,0,8"
                                     Foreground="#FFBFcbd9" />
                        <RadioButton GroupName="Theme" Content="🌙 深色模式"
                                     IsChecked="{Binding IsDarkTheme}"
                                     Foreground="#FFBFcbd9" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 🖼️ 背景设置 -->
            <Border Margin="0,0,0,16" Padding="20" CornerRadius="8"
                    Background="Transparent"
                    BorderBrush="#66FF4081" BorderThickness="0,0,0,1">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                        <TextBlock Grid.Column="0" Text="🖼️" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="背景设置" FontSize="16" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Margin="10,0,0,0">
                        <RadioButton Content="⬛ 无背景" GroupName="Bg"
                                     IsChecked="{Binding BackgroundType, Converter={StaticResource RadioBoolConverter}, ConverterParameter=0}"
                                     Margin="0,0,0,8"
                                     Foreground="#FFBFcbd9" />
                        <RadioButton Content="🌌 渐变 1" GroupName="Bg"
                                     IsChecked="{Binding BackgroundType, Converter={StaticResource RadioBoolConverter}, ConverterParameter=1}"
                                     Margin="0,0,0,8"
                                     Foreground="#FFBFcbd9" />
                        <RadioButton Content="🌊 渐变 2" GroupName="Bg"
                                     IsChecked="{Binding BackgroundType, Converter={StaticResource RadioBoolConverter}, ConverterParameter=2}"
                                     Margin="0,0,0,8"
                                     Foreground="#FFBFcbd9" />
                    </StackPanel>

                    <!-- 自定义图片 -->
                    <Border Margin="10,8,0,16" Padding="12" CornerRadius="6"
                            Background="#0DFFFFFF"
                            BorderBrush="#22FFFFFF" BorderThickness="1">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="📷 自定义图片"
                                       VerticalAlignment="Center" FontSize="13"
                                       Foreground="#FFBFcbd9" Margin="0,0,0,4" />
                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                    Content="选择图片"
                                    Command="{Binding SelectImageFileCommand}"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{Binding BackgroundValue}"
                                       FontSize="11" Foreground="#66FFFFFF"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="350" />
                        </Grid>
                    </Border>

                    <!-- 透明度 -->
                    <Border Margin="10,0,0,0" Padding="12" CornerRadius="6"
                            Background="#0DFFFFFF"
                            BorderBrush="#22FFFFFF" BorderThickness="1">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="🔆 背景透明度"
                                       FontSize="13" Foreground="#FFBFcbd9" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{Binding BackgroundOpacity, StringFormat='{}{0:P0}'}"
                                       FontSize="13" Foreground="#99FFFFFF"
                                       VerticalAlignment="Center" Margin="0,0,12,0" Width="40" />
                            <Slider Grid.Row="1" Grid.Column="1"
                                    Value="{Binding BackgroundOpacity}"
                                    Minimum="0.3" Maximum="1.0" TickFrequency="0.1"
                                    IsSnapToTickEnabled="True" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 🔄 更新设置 -->
            <Border Padding="20" CornerRadius="8"
                    Background="Transparent"
                    BorderBrush="#66E6A23C" BorderThickness="0,0,0,1">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                        <TextBlock Grid.Column="0" Text="🔄" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="更新设置" FontSize="16" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                    </Grid>

                    <Border Margin="10,0,0,0" Padding="12" CornerRadius="6"
                            Background="#0DFFFFFF"
                            BorderBrush="#22FFFFFF" BorderThickness="1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="🔔 自动检测版本更新"
                                       VerticalAlignment="Center" FontSize="13"
                                       Foreground="#FFBFcbd9" />
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding AutoCheckUpdates}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
