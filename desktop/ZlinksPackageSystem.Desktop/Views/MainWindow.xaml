<Window x:Class="ZlinksPackageSystem.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZlinksPackageSystem.Desktop.Views"
        xmlns:vm="clr-namespace:ZlinksPackageSystem.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <local:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <local:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameListViewModel}">
            <local:GameListView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" IsEnabled="{Binding IsLoggedIn}">
            <MenuItem Header="首页" Command="{Binding NavigateToHomeCommand}" />
            <MenuItem Header="游戏管理" Command="{Binding NavigateToGamesCommand}" />
            <MenuItem Header="产品管理" />
            <MenuItem Header="测试管理" />
            <Separator />
            <MenuItem Header="退出" Command="{Binding LogoutCommand}" />
        </Menu>

        <!-- Main Content -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>