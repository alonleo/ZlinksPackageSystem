<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zlinks.package_system.mapper.system.SysPostMapper">

    <select id="selectPostPage" resultType="com.zlinks.package_system.entity.system.SysPost">
        SELECT post_id, post_code, post_name, post_sort, status,
               create_by, create_time, update_by, update_time, remark
        FROM sys_post
        WHERE 1=1
        <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
            AND ${ew.sqlSegment}
        </if>
        ORDER BY post_sort
    </select>

</mapper>
