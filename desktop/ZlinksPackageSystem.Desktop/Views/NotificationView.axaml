<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ZlinksPackageSystem.Desktop.Views.NotificationView">

    <Grid Margin="20" RowDefinitions="Auto,*">
        <!-- 通知标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="🔔 通知" FontSize="16" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center" />
            <Border Background="#FF52C41A" CornerRadius="10"
                    Padding="6,2" HorizontalAlignment="Right"
                    IsVisible="{Binding UnreadCount, Converter={StaticResource IntPositiveToBoolConverter}}">
                <TextBlock Foreground="White" FontSize="11">
                    <Run Text="{Binding UnreadCount}" /><Run Text=" 条未读" />
                </TextBlock>
            </Border>
        </Grid>

        <!-- 通知列表 -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Notifications}"
                 BorderThickness="0" Background="Transparent">
            <ListBox.Styles>
                <Style Selector="ListBox ScrollViewer">
                    <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
                </Style>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                            Background="{Binding IsRead, Converter={StaticResource ReadToBackgroundConverter}}"
                            PointerPressed="NotificationItem_PointerPressed">
                        <Grid RowDefinitions="Auto,Auto">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,Auto,*,Auto">
                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                         Fill="{Binding Urgency, Converter={StaticResource UrgencyToColorConverter}}"
                                         Margin="0,0,6,0" VerticalAlignment="Center" />
                                <Ellipse Grid.Column="1" Width="6" Height="6" Fill="#FF52C41A"
                                         Margin="0,0,8,0" VerticalAlignment="Center"
                                         IsVisible="{Binding !IsRead}" />
                                <TextBlock Grid.Column="2" Text="{Binding Message}"
                                           FontSize="13" VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="#FFBFcbd9"
                                           Opacity="{Binding IsRead, Converter={StaticResource ReadToOpacityConverter}}" />
                                <TextBlock Grid.Column="3" Text="{Binding Time, StringFormat='{}{0:MM-dd HH:mm}'}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="#99FFFFFF"
                                           Opacity="{Binding IsRead, Converter={StaticResource ReadToOpacityConverter}}" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="14,4,0,0">
                                <TextBlock Text="{Binding Publisher, StringFormat='发布人: {0}'}"
                                           FontSize="11" Foreground="#77FFFFFF" VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>