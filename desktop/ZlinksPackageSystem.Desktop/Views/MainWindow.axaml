<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZlinksPackageSystem.Desktop.Views"
        xmlns:vm="clr-namespace:ZlinksPackageSystem.Desktop.ViewModels"
        x:Class="ZlinksPackageSystem.Desktop.Views.MainWindow"
        Title="{Binding Title}"
                        Width="1200" Height="1050"
                        MinWidth="1200" MinHeight="1050"
                        WindowStartupLocation="CenterScreen"
                SystemDecorations="None"
                CanResize="True"
                Background="Transparent"
                TransparencyLevelHint="None"
                Padding="4"
                Icon="/Assets/icon.png"
                PointerMoved="Window_PointerMoved"
                PointerPressed="Window_PointerPressed">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <local:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <local:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameListViewModel}">
            <local:GameListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductViewModel}">
            <local:ProductView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ParameterViewModel}">
            <local:ParameterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestViewModel}">
            <local:TestView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ToolLibraryViewModel}">
            <local:ToolLibraryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotificationViewModel}">
            <local:NotificationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <local:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <Style Selector="Button.CaptionButton">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFBFcbd9" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
        <Style Selector="Button.CaptionButton:pointerover">
            <Setter Property="Background" Value="#44FFFFFF" />
        </Style>
        <Style Selector="Button.CloseButton">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFBFcbd9" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
        <Style Selector="Button.CloseButton:pointerover">
            <Setter Property="Background" Value="#E81123" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid>
        <!-- Background Layer -->
        <Rectangle Fill="{Binding BackgroundBrush}"
                   Opacity="{Binding BackgroundOpacity}"
                   IsHitTestVisible="False" />

        <!-- Dimming overlay to keep content readable -->
        <Rectangle Fill="{DynamicResource WindowDimOverlay}" IsHitTestVisible="False" />

        <Border CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Custom Title Bar -->
                <Border Grid.Row="0" Background="Transparent" PointerPressed="TitleBar_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   Foreground="{DynamicResource ForegroundPrimary}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="MinimizeButton"
                                    Content="─"
                                    Click="MinimizeButton_Click"
                                    Classes="CaptionButton" />
                            <Button x:Name="MaximizeButton"
                                    Content="□"
                                    Click="MaximizeButton_Click"
                                    Classes="CaptionButton" />
                            <Button x:Name="CloseButton"
                                    Content="✕"
                                    Click="CloseButton_Click"
                                    Classes="CloseButton" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Menu Bar -->
                <DockPanel Grid.Row="1"
                           IsVisible="{Binding IsLoggedIn}"
                           LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Margin="0,6,14,6"
                            Padding="14,6"
                            Background="{DynamicResource SubItemBackground}"
                            Foreground="{DynamicResource ForegroundPrimary}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Cursor="Hand">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#FF1976D2"
                                        CornerRadius="3"
                                        Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PrimaryRole}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ForegroundPrimary}"
                                               FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="{Binding DisplayUsername}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ForegroundPrimary}" />
                                <TextBlock Text="▾" FontSize="10" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundPrimary}" />
                            </StackPanel>
                        </Button.Content>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem>
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="角色" Foreground="#909399" FontSize="12" />
                                            <TextBlock Text="{Binding PrimaryRole}" Foreground="{DynamicResource ForegroundPrimary}" FontSize="12" FontWeight="Bold" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem>
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="用户名" Foreground="#909399" FontSize="12" />
                                            <TextBlock Text="{Binding DisplayUsername}" Foreground="{DynamicResource ForegroundPrimary}" FontSize="12" FontWeight="Bold" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="🔧 修改账号" Command="{Binding ChangeAccountCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Menu HorizontalAlignment="Center" VerticalAlignment="Center">
                        <MenuItem Header="🏠 首页" Command="{Binding NavigateToHomeCommand}" IsVisible="{Binding IsHomeVisible}" />
                        <MenuItem Header="🎮 游戏" Command="{Binding NavigateToGamesCommand}" IsVisible="{Binding IsGamesVisible}" />
                        <MenuItem Header="📦 产品" Command="{Binding NavigateToProductsCommand}" IsVisible="{Binding IsProductsVisible}" />
                        <MenuItem Header="📋 参数" Command="{Binding NavigateToParametersCommand}" IsVisible="{Binding IsParametersVisible}" />
                        <MenuItem Header="🧪 测试" Command="{Binding NavigateToTestsCommand}" IsVisible="{Binding IsTestsVisible}" />
                        <MenuItem Header="🔧 工具库" Command="{Binding NavigateToToolLibraryCommand}" IsVisible="{Binding IsToolLibraryVisible}" />
                        <MenuItem Header="🔔 消息中心" Command="{Binding NavigateToNotificationCommand}" IsVisible="{Binding IsNotificationVisible}" />
                        <MenuItem Header="⚙️ 设置" Command="{Binding NavigateToSettingsCommand}" IsVisible="{Binding IsSettingsVisible}" />
                        <Separator />
                        <MenuItem Header="🚪 退出" Command="{Binding LogoutCommand}" />
                    </Menu>
                </DockPanel>

                <!-- Main Content -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding CurrentViewModel}" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
