<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ZlinksPackageSystem.Desktop.Views.LoginView"
             Loaded="LoginView_Loaded">

    <Grid Background="Transparent">

        <!-- 登录卡片 -->
        <Border CornerRadius="14" Padding="40,36"
                MaxWidth="400"
                Background="Transparent"
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Stretch">

                <!-- Logo 区 -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                    <TextBlock Text="📦" FontSize="48"
                               HorizontalAlignment="Center" Margin="0,0,0,12" />
                    <TextBlock Text="Zlinks Package System"
                              FontSize="22" FontWeight="Bold"
                              Foreground="{DynamicResource ForegroundPrimary}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="游戏包管理系统"
                              FontSize="13"
                              Foreground="{DynamicResource ForegroundSecondary}"
                              HorizontalAlignment="Center"
                              Margin="0,4,0,0" />
                </StackPanel>

                <!-- 用户名 -->
                <Border Margin="0,0,0,14" Padding="10,0" CornerRadius="6"
                        Background="#1AFFFFFF"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="👤" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding Username}"
                                 Watermark="请输入用户名"
                                 Background="Transparent"
                                 BorderThickness="0" />
                    </Grid>
                </Border>

                <!-- 密码 -->
                <Border Margin="0,0,0,8" Padding="10,0" CornerRadius="6"
                        Background="#1AFFFFFF"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="🔒" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 x:Name="PasswordBoxCtrl"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="请输入密码"
                                 PasswordChar="●"
                                 Background="Transparent"
                                 BorderThickness="0" />
                    </Grid>
                </Border>

                <!-- 错误提示 -->
                <TextBlock Text="{Binding ErrorMessage}"
                          Foreground="#FFF56C6C"
                          FontSize="12"
                          IsVisible="{Binding HasError}"
                          Margin="4,4,0,8" />

                <!-- 记住密码 -->
                <CheckBox Content="记住密码"
                          IsChecked="{Binding RememberPassword}"
                          Foreground="{DynamicResource ForegroundSecondary}"
                          FontSize="12"
                          Margin="0,4,0,16" />

                <!-- 登录按钮 -->
                <Button Content="🔑 登  录"
                        Command="{Binding DataContext.LoginCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        HorizontalAlignment="Stretch"
                        Height="42"
                        FontSize="15" FontWeight="Bold"
                        Margin="0,0,0,12">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF1976D2" Offset="0.0" />
                            <GradientStop Color="#FF1E88E5" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- 忘记密码 -->
                <Button Content="忘记密码？"
                        Command="{Binding DataContext.ForgotPasswordCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        Foreground="#66BFcbd9"
                        FontSize="12"
                        Background="Transparent"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
