<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ZlinksPackageSystem.Desktop.ViewModels"
             xmlns:models="clr-namespace:ZlinksPackageSystem.Desktop.Models"
             xmlns:local="clr-namespace:ZlinksPackageSystem.Desktop.Views"
             x:Class="ZlinksPackageSystem.Desktop.Views.ToolLibraryView">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFBFcbd9" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFBFcbd9" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#FF1976D2" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="#FFBFcbd9" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFBFcbd9" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFBFcbd9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style Selector="DataGridRow:pointerover DataGridCell">
            <Setter Property="Background" Value="#0DFFFFFF" />
        </Style>
        <Style Selector="DataGridRow:selected DataGridCell">
            <Setter Property="Background" Value="#1A1976D2" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="Foreground" Value="#FFBFcbd9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </UserControl.Styles>

        <Grid>
            <DockPanel Margin="20" LastChildFill="True">

            <!-- 顶部条：标题 + 搜索 + 新建 + 同步本地工具 -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,16" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Column="0" Text="🔧 工具库" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource ForegroundPrimary}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <TextBox Grid.Column="1" Text="{Binding SearchText}"
                     Watermark="🔍 搜索工具名称..."
                     VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="🔍"
                    Margin="8,0,0,0" Width="38"
                    Command="{Binding FilterProjectsCommand}"
                    VerticalAlignment="Center" />
            <Button Grid.Column="3" Content="＋ 新建工具"
                    Command="{Binding OpenAddDialogCommand}"
                    Margin="8,0,0,0" Width="110"
                    BorderBrush="#FF1976D2" Foreground="#FF1976D2"
                    VerticalAlignment="Center" />
            <Button Grid.Column="4" Content="📥 导入"
                    Command="{Binding ImportToolsCommand}" Width="80"
                    Margin="8,0,0,0" VerticalAlignment="Center" />
            <Button Grid.Column="5" Content="📤 导出"
                    Command="{Binding ExportToolsCommand}" Width="80"
                    Margin="8,0,0,0" VerticalAlignment="Center" />
            <Button Grid.Column="6" Margin="8,0,0,0" Padding="10,4"
                    BorderBrush="#FFFFA940" Foreground="#FFFFA940"
                    IsEnabled="{Binding IsBatchSyncing, Converter={StaticResource BooleanInverseConverter}}"
                    ToolTip.Tip="把本地尚未推送到后台的用户工具批量推送到后台管理系统"
                    Command="{Binding SyncLocalToolsCommand}"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="📤 同步本地" VerticalAlignment="Center">
                        <TextBlock.IsVisible>
                            <Binding Path="IsBatchSyncing" Converter="{StaticResource BooleanInverseConverter}" />
                        </TextBlock.IsVisible>
                    </TextBlock>
                    <TextBlock Text="同步中…" VerticalAlignment="Center"
                               IsVisible="{Binding IsBatchSyncing}" />
                    <Border Background="#FFFFA940" CornerRadius="8"
                            Padding="6,1"
                            IsVisible="{Binding HasPendingSync}">
                        <TextBlock Foreground="{DynamicResource ForegroundPrimary}" FontSize="10"
                                   Text="{Binding PendingSyncTools.Count}" />
                    </Border>
                </StackPanel>
            </Button>
            <Button Grid.Column="7" Content="↻ 重新加载" Width="90"
                    Margin="8,0,0,0" VerticalAlignment="Center"
                    Command="{Binding LoadProjectsCommand}" />
            <TextBlock Grid.Column="8" Text="{Binding CacheUpdateTimeText}"
                       FontSize="10" Foreground="#66FFFFFF"
                       VerticalAlignment="Center" Margin="8,0,0,0"
                       IsVisible="{Binding IsFromCache}" />
        </Grid>

        <!-- 可用运行环境面板 -->
                <Border DockPanel.Dock="Top" Margin="0,0,0,14" Padding="12,10"
                        Background="{DynamicResource SubItemBackground}" CornerRadius="8"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                            <TextBlock Grid.Column="0" Text="🖥️ 可用运行环境（启动时已自动检测）"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundPrimary}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="🔄 重新检测全部"
                                    Command="{Binding ReDetectEnvironmentsCommand}"
                                    FontSize="11" Padding="10,4" />
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding AvailableEnvironments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                                             <DataTemplate DataType="models:RuntimeEnvironment">
                                                                 <Border Margin="0,0,6,6" Padding="8,5" CornerRadius="4"
                                                                         Background="#15FFFFFF" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                                         Cursor="Hand"
                                                                         PointerPressed="Runtime_PointerPressed">
                                                                     <StackPanel Spacing="4">
                                                                         <StackPanel Orientation="Horizontal" Spacing="6">
                                                                             <TextBlock Text="{Binding Icon}" FontSize="14"
                                                                                        VerticalAlignment="Center" />
                                                                             <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                                                      Fill="{Binding IsAvailable, Converter={StaticResource BoolToColorConverter}}" />
                                                                             <TextBlock Text="{Binding Language}" FontSize="11"
                                                                                        FontWeight="SemiBold"
                                                                                        Foreground="{DynamicResource ForegroundPrimary}" VerticalAlignment="Center" />
                                                                         </StackPanel>
                                                                         <StackPanel Spacing="3" IsVisible="{Binding IsExpanded}">
                                                                             <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                                                        Foreground="{DynamicResource ForegroundSecondary}" />
                                                                             <TextBlock Text="{Binding ExecutablePath}" FontSize="10"
                                                                                        Foreground="{DynamicResource ForegroundSecondary}"
                                                                                        TextWrapping="Wrap" />
                                                                             <Button Content="🔄 重新检测此环境" FontSize="10" Padding="8,2"
                                                                                     HorizontalAlignment="Left"
                                                                                     Command="{Binding DataContext.ReDetectSingleCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                                                                     CommandParameter="{Binding Language}" />
                                                                         </StackPanel>
                                                                     </StackPanel>
                                                                 </Border>
                                                             </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 卡片滚动区 - 始终占据剩余空间，超出时自动出现滚动条 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
            <ItemsControl ItemsSource="{Binding Projects}"
                          HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:ToolProject">
                        <Border Width="280" Margin="0,0,14,14" Padding="0"
                                                        CornerRadius="10" Background="#1AFFFFFF"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                <!-- 卡片标题栏 -->
                                <Border Grid.Row="0" Padding="14,12" CornerRadius="10,10,0,0"
                                        Background="#1A1976D2"
                                        PointerPressed="Card_PointerPressed">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"
                                                       Foreground="{DynamicResource ForegroundPrimary}" />
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Category, StringFormat='🏷 {0}'}"
                                                           FontSize="11" Foreground="{DynamicResource ForegroundSecondary}" />
                                                <Border Padding="4,1" CornerRadius="3"
                                                        Background="#FF8C00"
                                                        IsVisible="{Binding IsSystemBuiltin}">
                                                    <TextBlock Text="⚙ 系统内置" FontSize="9" Foreground="{DynamicResource ForegroundPrimary}" />
                                                </Border>
                                                <Border Padding="4,1" CornerRadius="3"
                                                        Background="#FFFFA940"
                                                        IsVisible="{Binding IsPendingSync}">
                                                    <TextBlock Text="{Binding SyncBadgeText}" FontSize="9" Foreground="White" />
                                                </Border>
                                                <Border Padding="4,1" CornerRadius="3"
                                                        Background="#6678A0"
                                                        IsVisible="{Binding IsFromLocalSnapshot}">
                                                    <TextBlock Text="📦 缓存" FontSize="9" Foreground="White" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" Padding="6,3" CornerRadius="4"
                                                Background="#1AFFFFFF" VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                         IsVisible="{Binding IsRunning}"
                                                         Fill="#FF52C41A" />
                                                <TextBlock Text="{Binding Status}" FontSize="10"
                                                           Foreground="{DynamicResource ForegroundPrimary}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- 描述 -->
                                <TextBlock Grid.Row="1" Text="{Binding Description}"
                                           FontSize="12" Foreground="{DynamicResource ForegroundSecondary}"
                                           TextWrapping="Wrap" Margin="14,10,14,6"
                                           MaxHeight="40" TextTrimming="CharacterEllipsis" />

                                <!-- 元信息 -->
                                <StackPanel Grid.Row="2" Margin="14,0,14,8">
                                    <TextBlock FontSize="11" Foreground="#66FFFFFF">
                                        <Run Text="版本: " /><Run Text="{Binding Version}" />
                                        <Run Text="  |  " /><Run Text="负责人: " /><Run Text="{Binding Manager}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding CreateTime, StringFormat='📅 {0:yyyy-MM-dd}'}"
                                               FontSize="11" Foreground="#44FFFFFF" Margin="0,2,0,0" />
                                    <TextBlock FontSize="11" Foreground="#44FFFFFF" Margin="0,2,0,0">
                                        <Run Text="🐍 语言: " /><Run Text="{Binding Language}" />
                                    </TextBlock>
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <Grid Grid.Row="3" Margin="14,0,14,12" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*">
                                    <!-- ▶ 运行 / ⏹ 关闭 互斥显示 -->
                                    <Button Grid.Column="0" Content="▶ 运行" FontSize="11"
                                            BorderBrush="#FF52C41A" Foreground="#FF52C41A"
                                            IsVisible="{Binding IsRunning, Converter={StaticResource BooleanInverseConverter}}"
                                            Command="{Binding DataContext.RunToolCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="0" Content="⏹ 关闭" FontSize="11"
                                            BorderBrush="#FFF56C6C" Foreground="#FFF56C6C"
                                            IsVisible="{Binding IsRunning}"
                                            Command="{Binding DataContext.StopToolCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="1" Content="✏ 编辑" FontSize="11"
                                            BorderBrush="#FF1976D2" Foreground="#FF1976D2"
                                            Margin="6,0,0,0"
                                            Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <!-- 📤 单条同步:仅当该卡片处于待同步状态时显示,同步中禁用并切换文案 -->
                                    <Button Grid.Column="2" FontSize="11"
                                            BorderBrush="#FFFFA940" Foreground="#FFFFA940"
                                            Margin="6,0,0,0" Padding="8,0"
                                            IsVisible="{Binding IsPendingSync}"
                                            IsEnabled="{Binding IsSyncing, Converter={StaticResource BooleanInverseConverter}}"
                                            ToolTip.Tip="将本条工具推送到后台管理系统"
                                            Command="{Binding DataContext.SyncSingleToolCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Panel>
                                            <TextBlock Text="📤 同步"
                                                       IsVisible="{Binding IsSyncing, Converter={StaticResource BooleanInverseConverter}}" />
                                            <TextBlock Text="同步中…" IsVisible="{Binding IsSyncing}" />
                                        </Panel>
                                    </Button>
                                    <!-- 📋 日志:仅当有运行记录时显示 -->
                                    <Button Grid.Column="3" Content="📋 日志" FontSize="11"
                                            BorderBrush="#FF52C41A" Foreground="#FF52C41A"
                                            Margin="6,0,0,0"
                                            IsVisible="{Binding HasRunLog}"
                                            Command="{Binding DataContext.ViewToolLogCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="4" Content="🗑 删除" FontSize="11"
                                            BorderBrush="#FFF56C6C" Foreground="#FFF56C6C"
                                            Margin="6,0,0,0"
                                            Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

    <!-- 新建/编辑工具弹窗 -->
    <Border IsVisible="{Binding IsEditing}"
            Background="#80000000"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="720" MaxHeight="900" Padding="22" CornerRadius="12"
                        Background="{DynamicResource WindowBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="0">
                    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                        <!-- ===== Tab 1: 工具信息 ===== -->
                        <TabItem Header="📋 工具信息">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,0,8">
                            <StackPanel Spacing="10">

                                <!-- 弹窗标题 -->
                                <TextBlock Text="📝 工具信息" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ForegroundPrimary}" />

                                <Separator />

                                <!-- ============ 基本信息 ============ -->
                                <TextBlock Text="📋 基本信息" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundPrimary}" />

                                <Grid ColumnDefinitions="*,*">
                                    <TextBox Grid.Column="0" Text="{Binding EditName}" Watermark="🔧 工具名称 *" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="1" Text="{Binding EditVersion}" Watermark="🏷 版本号" Margin="4,0,0,0" />
                                </Grid>

                                <TextBox Text="{Binding EditDescription}" Watermark="📝 描述信息" Height="50"
                                         AcceptsReturn="True" TextWrapping="Wrap" />

                                <Grid ColumnDefinitions="*,*">
                                    <TextBox Grid.Column="0" Text="{Binding EditCategory}" Watermark="📂 分类" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="1" Text="{Binding EditManager}" Watermark="👤 负责人" Margin="4,0,0,0" />
                                </Grid>

                                <Separator />

                                <!-- ===== Git 仓库面板 ===== -->
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="📥 Git 仓库（可选 · 一次性克隆 / 或更新现有仓库）"
                                                   FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundPrimary}"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="{Binding IsGitPanelExpanded, Converter={StaticResource BoolToExpandGlyphConverter}}"
                                                Command="{Binding ToggleGitPanelCommand}"
                                                Width="34" Height="26" Padding="0" />
                                    </Grid>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsGitPanelExpanded}">
                                        <!-- Git URL + 克隆目标（仅新建） -->
                                        <TextBox Text="{Binding EditGitUrl}"
                                                 Watermark="Git URL（HTTPS 或 SSH;本地已有仓库可留空,在拉取前再设置）" />
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <TextBox Grid.Column="0" Text="{Binding EditCloneDirectory}"
                                                     Watermark="克隆目标父目录（如 D:\tools 或 /home/user/tools,若已含 .git 会被自动识别）"
                                                     Margin="0,0,6,0" />
                                            <Button Grid.Column="1" Content="📁 浏览" Width="80"
                                                    Command="{Binding BrowseCloneDirectoryCommand}" />
                                            <Button Grid.Column="2" Content="🔍 检测" Width="80" Margin="0,0,0,0"
                                                    IsEnabled="{Binding IsDetectingLocalGit, Converter={StaticResource BooleanInverseConverter}}"
                                                    Command="{Binding DetectLocalGitNowCommand}" />
                                        </Grid>

                                        <!-- 本地 .git 自动检测结果提示(共享) -->
                                        <Border Padding="8,6" CornerRadius="4"
                                                Background="#0DFFFFFF"
                                                BorderBrush="{DynamicResource CardBorder}"
                                                BorderThickness="1"
                                                IsVisible="{Binding LocalGitHint, Converter={StaticResource StringNotEmptyConverter}}">
                                            <TextBlock Text="{Binding LocalGitHint}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource ForegroundSecondary}" />
                                        </Border>

                                        <!-- 远端名(新建/编辑共享)— 默认 origin,可改 -->
                                        <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,0">
                                            <TextBlock Grid.Column="0" Text="远端名:" VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       FontSize="11" Foreground="{DynamicResource ForegroundSecondary}" />
                                            <TextBox Grid.Column="1" Text="{Binding EditRemoteName, Mode=TwoWay}"
                                                     Watermark="origin" />
                                        </Grid>

                                        <!-- 本机 Git 检测（共享） -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                     Fill="{Binding GitEnvironment.IsInstalled, Converter={StaticResource BoolToColorConverter}, FallbackValue=#666666}" />
                                            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource ForegroundPrimary}">
                                                <Run Text="本地 Git: " />
                                                <Run Text="{Binding GitEnvironment.Version, FallbackValue='点击右侧刷新检测', TargetNullValue='点击右侧刷新检测'}" />
                                            </TextBlock>
                                            <Button Content="🔄 刷新" Padding="6,2" FontSize="10"
                                                    IsEnabled="{Binding IsDetectingGit, Converter={StaticResource BooleanInverseConverter}}"
                                                    Command="{Binding RefreshGitEnvironmentCommand}" />
                                        </StackPanel>

                                        <!-- 克隆按钮行（仅新建） -->
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    IsVisible="{Binding IsNewProject}">
                                            <Button Content="📥 克隆" Width="110"
                                                    Background="#FF1976D2" BorderBrush="#FF1976D2" Foreground="{DynamicResource ForegroundPrimary}"
                                                    IsVisible="{Binding IsCloning, Converter={StaticResource BooleanInverseConverter}}"
                                                    IsEnabled="{Binding GitEnvironment.IsInstalled}"
                                                    Command="{Binding StartCloneCommand}" />
                                            <Button Content="⏳ 取消克隆" Width="110"
                                                    IsVisible="{Binding IsCloning}"
                                                    BorderBrush="#FFF56C6C" Foreground="#FFF56C6C"
                                                    Command="{Binding CancelCloneCommand}" />
                                            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource ForegroundSecondary}"
                                                       Text="{Binding CloneProgressText}" />
                                        </StackPanel>

                                        <!-- 🆕 拉取更新按钮行（仅编辑现有项目） -->
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    IsVisible="{Binding !IsNewProject}">
                                            <Button Content="📥 拉取更新" Width="110"
                                                    Background="#FF52C41A" BorderBrush="#FF52C41A" Foreground="{DynamicResource ForegroundPrimary}"
                                                    IsVisible="{Binding IsPulling, Converter={StaticResource BooleanInverseConverter}}"
                                                    IsEnabled="{Binding GitEnvironment.IsInstalled}"
                                                    Command="{Binding StartPullCommand}" />
                                            <Button Content="⏳ 取消拉取" Width="110"
                                                    IsVisible="{Binding IsPulling}"
                                                    BorderBrush="#FFF56C6C" Foreground="#FFF56C6C"
                                                    Command="{Binding CancelPullCommand}" />
                                            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource ForegroundSecondary}"
                                                       Text="{Binding PullProgressText}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Separator />

                                <!-- 操作按钮已移至 TabControl 外层底栏(跨两个 Tab 共享) -->
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ===== Tab 2: 启动方式 ===== -->
                        <TabItem Header="🚀 启动方式">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,0,8">
                            <StackPanel Spacing="10">

                                <!-- ============ 运行模式选择 ============ -->
                                <TextBlock Text="🚀 启动方式" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundPrimary}" />

                                <StackPanel Spacing="4">
                                    <TextBlock Text="运行模式 *" FontSize="11" Foreground="{DynamicResource ForegroundSecondary}" />
                                    <ComboBox HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding RunModeDisplayNames}"
                                              SelectedIndex="{Binding EditRunMode, Converter={StaticResource EnumToIntConverter}}" />
                                </StackPanel>

                                <!-- 脚本模式：显示 解释器 + 脚本 -->
                                <StackPanel Spacing="6"
                                            IsVisible="{Binding EditRunMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Script}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="编程语言 *（下拉中列出已检测到的运行环境）" FontSize="11" Foreground="{DynamicResource ForegroundSecondary}" />
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding AvailableEnvironments}"
                                                  SelectedItem="{Binding SelectedEnvironment, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="models:RuntimeEnvironment">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Icon}" FontSize="13" VerticalAlignment="Center" />
                                                        <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                                                 Fill="{Binding IsAvailable, Converter={StaticResource BoolToColorConverter}}" />
                                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding EditInterpreterPath}"
                                                 Watermark="解释器路径（留空使用自动检测）" Margin="0,0,6,0" />
                                        <Button Grid.Column="1" Content="📁 浏览" Width="80"
                                                Command="{Binding BrowseInterpreterCommand}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding EditScriptPath}"
                                                 Watermark="脚本路径（如 C:\tools\build.py）*" Margin="0,0,6,0" />
                                        <Button Grid.Column="1" Content="📁 浏览" Width="80"
                                                Command="{Binding BrowseScriptCommand}" />
                                    </Grid>

                                    <!-- ===== Python 虚拟环境(仅 Python 工具显示)===== -->
                                    <Border Padding="10,8"
                                            CornerRadius="6"
                                            Background="#0DFFFFFF"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1"
                                            IsVisible="{Binding EditLanguage, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=python}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="🐍 Python 虚拟环境（可选 · 自动创建并安装依赖）"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundPrimary}" />

                                            <CheckBox Content="启动前自动创建虚拟环境并安装依赖"
                                                      IsChecked="{Binding EditCreateVenv, Mode=TwoWay}" />

                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding EditVenvDirectory, Mode=TwoWay}"
                                                         Watermark="venv 目录（留空 = {工作目录}/.venv）"
                                                         Margin="0,0,6,0"
                                                         IsEnabled="{Binding EditCreateVenv}" />
                                            </Grid>

                                            <CheckBox Content="自动 pip install -r requirements.txt"
                                                      IsChecked="{Binding EditAutoInstallRequirements, Mode=TwoWay}"
                                                      IsEnabled="{Binding EditCreateVenv}" />

                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding EditRequirementsPath, Mode=TwoWay}"
                                                         Watermark="requirements.txt 路径（绝对路径或相对工作目录）"
                                                         Margin="0,0,6,0"
                                                         IsEnabled="{Binding EditCreateVenv}" />
                                                <Button Grid.Column="1" Content="📁 浏览" Width="80"
                                                        Command="{Binding BrowseRequirementsCommand}"
                                                        IsEnabled="{Binding EditCreateVenv}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding EditPipMirrorUrl, Mode=TwoWay}"
                                                         Watermark="pip 镜像源 URL（可选，如 https://pypi.tuna.tsinghua.edu.cn/simple）"
                                                         Margin="0,0,6,0"
                                                         IsEnabled="{Binding EditCreateVenv}" />
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="📦 立即创建并安装依赖" Width="200"
                                                        HorizontalContentAlignment="Center"
                                                        Command="{Binding CreateVenvNowCommand}"
                                                        IsEnabled="{Binding EditCreateVenv}" />
                                                <Button Content="取消" Width="80"
                                                        Command="{Binding CancelCreateVenvCommand}"
                                                        IsVisible="{Binding IsCreatingVenv}" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding VenvProgressText}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ForegroundSecondary}"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding IsCreatingVenv}" />

                                            <TextBlock Text="提示:勾选「自动 pip install」时,首次启动会先创建 venv 再安装依赖,后续启动会复用已存在的 venv(仅在 requirements.txt 修改时间晚于 venv 时才会重装)。"
                                                       FontSize="10"
                                                       Foreground="#66FFFFFF"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- 本地可执行程序模式：单可执行文件路径 -->
                                <StackPanel Spacing="6"
                                            IsVisible="{Binding EditRunMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=LocalExecutable}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding EditExecutablePath}"
                                                 Watermark="可执行程序绝对路径（如 C:\tools\ffmpeg.exe）*" Margin="0,0,6,0" />
                                        <Button Grid.Column="1" Content="📁 浏览" Width="80"
                                                Command="{Binding BrowseExecutableCommand}" />
                                    </Grid>
                                    <TextBlock Text="提示：本地可执行程序模式不使用检测到的运行环境，直接启动该 .exe。"
                                               FontSize="10" Foreground="#66FFFFFF" />
                                </StackPanel>

                                <!-- 工作目录（两种模式都有） -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding EditWorkingDirectory}"
                                             Watermark="工作目录（留空使用脚本/可执行文件所在目录）" Margin="0,0,6,0" />
                                    <Button Grid.Column="1" Content="📁 浏览" Width="80"
                                            Command="{Binding BrowseWorkingDirectoryCommand}" />
                                </Grid>

                                <!-- 参数列表 -->
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="📋 参数列表"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundPrimary}" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="＋ 添加参数"
                                                Command="{Binding AddParameterCommand}"
                                                BorderBrush="#FF52C41A" Foreground="#FF52C41A"
                                                FontSize="11" Padding="10,4" />
                                    </Grid>

                                    <Border Background="{DynamicResource SubItemBackground}" CornerRadius="6" Padding="0"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Height="144">
                                        <Grid RowDefinitions="Auto,*">
                                            <!-- 表头（始终可见） -->
                                            <Border Grid.Row="0" Background="#1AFFFFFF" Padding="8,6">
                                                <Grid ColumnDefinitions="100,*,*,Auto,50">
                                                    <TextBlock Grid.Column="0" Text="前缀" FontSize="11"
                                                               Foreground="{DynamicResource ForegroundSecondary}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="参数名" FontSize="11"
                                                               Foreground="{DynamicResource ForegroundSecondary}" VerticalAlignment="Center"
                                                               Margin="4,0,0,0" />
                                                    <TextBlock Grid.Column="2" Text="参数值" FontSize="11"
                                                               Foreground="{DynamicResource ForegroundSecondary}" VerticalAlignment="Center"
                                                               Margin="4,0,0,0" />
                                                    <TextBlock Grid.Column="3" Text="必填" FontSize="11"
                                                               Foreground="{DynamicResource ForegroundSecondary}" VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" Margin="8,0,8,0"
                                                               ToolTip.Tip="勾选后,运行工具前会要求用户输入该参数值" />
                                                    <TextBlock Grid.Column="4" Text="操作" FontSize="11"
                                                               Foreground="{DynamicResource ForegroundSecondary}" VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <!-- 滚动行列表：Padding 写在 ScrollViewer 上以让滚动条算到真实底部 -->
                                            <ScrollViewer Grid.Row="1"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Padding="6,4">
                                                <ItemsControl ItemsSource="{Binding EditParameters}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="6" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="100,*,*,Auto,50">
                                                                <TextBox Grid.Column="0" Text="{Binding Prefix, Mode=TwoWay}"
                                                                         Watermark="--"
                                                                         FontFamily="Consolas, Courier New, monospace" />
                                                                <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                                                         Watermark="参数名"
                                                                         Margin="4,0,0,0" />
                                                                <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay}"
                                                                         Watermark="参数值"
                                                                         Margin="4,0,0,0" />
                                                                <CheckBox Grid.Column="3"
                                                                          IsChecked="{Binding RequireInput, Mode=TwoWay}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Margin="8,0,8,0"
                                                                          ToolTip.Tip="勾选后,运行工具前会要求用户输入该参数值" />
                                                                <Button Grid.Column="4" Content="🗑"
                                                                        Padding="6,2" FontSize="11"
                                                                        BorderBrush="#FFF56C6C"
                                                                        Foreground="#FFF56C6C"
                                                                        HorizontalAlignment="Center"
                                                                        Command="{Binding DataContext.RemoveParameterCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Separator />

                                <!-- 操作按钮已移至 TabControl 外层底栏(跨所有 Tab 共享) -->
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ===== Tab 2: 通知 ===== -->
                        <TabItem Header="📢 通知">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,0,8">
                            <StackPanel Spacing="10">
                                <TextBlock Text="📢 通知配置（Q3-C：默认继承全局设置）"
                                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundPrimary}" />

                                <!-- 顶部操作行：使用全局设置 + 显隐 + 测试 -->
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <CheckBox Grid.Column="0" Content="使用全局通知设置"
                                              IsChecked="{Binding EditNotification.UseGlobalSettings}" />
                                    <Button Grid.Column="1" Content="👁"
                                            Command="{Binding ToggleSecretsVisibilityCommand}"
                                            Width="36" ToolTip.Tip="显隐 App Secret" />
                                    <Button Grid.Column="2" Content="🧪 一键测试全部"
                                            Command="{Binding TestNotificationCommand}"
                                            Width="140" Margin="6,0,0,0"
                                            ToolTip.Tip="遍历当前所有渠道发送测试" />
                                </Grid>

                                <!-- 三段式触发 -->
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <CheckBox Content="▶ 启动时" IsChecked="{Binding EditNotification.NotifyOnStart}" />
                                    <CheckBox Content="✅ 成功时" IsChecked="{Binding EditNotification.NotifyOnSuccess}" />
                                    <CheckBox Content="❌ 失败时" IsChecked="{Binding EditNotification.NotifyOnFailure}" />
                                </StackPanel>

                                <!-- 输出截断 -->
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="脚本输出最大字符数："
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{DynamicResource ForegroundPrimary}" />
                                    <NumericUpDown Grid.Column="1"
                                                   Value="{Binding EditNotification.MaxOutputChars}"
                                                   Minimum="0" Maximum="100000" />
                                </Grid>

                                <Separator />

                                <!-- 渠道列表：继承全局时禁用 -->
                                <TextBlock Text="📡 通知渠道（继承全局时禁用）" FontSize="12" Foreground="{DynamicResource ForegroundSecondary}" />
                                <Border IsEnabled="{Binding EditNotification.UseGlobalSettings, Converter={StaticResource BooleanInverseConverter}}"
                                        local:FeishuChannelEditor.RemoveRequested="OnNotificationChannelRemoveRequested"
                                        local:FeishuChannelEditor.TestRequested="OnNotificationChannelTestRequested">
                                    <ItemsControl ItemsSource="{Binding EditNotification.Channels}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <local:FeishuChannelEditor />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                                <Button Content="＋ 添加渠道" Command="{Binding AddNotificationChannelCommand}"
                                        HorizontalAlignment="Left"
                                        IsEnabled="{Binding EditNotification.UseGlobalSettings, Converter={StaticResource BooleanInverseConverter}}" />

                                <Separator />

                                <!-- 操作按钮已移至 TabControl 外层底栏(跨所有 Tab 共享) -->
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                    <!-- ===== 弹窗固定底栏:取消/保存(跨所有 Tab 共享)===== -->
                    <Border Padding="14,10,14,2" BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource CardBorder}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="取消" Width="80"
                                    Command="{Binding CancelEditCommand}" />
                            <Button Content="💾 保存" Width="100"
                                    Background="#FF1976D2" BorderBrush="#FF1976D2"
                                    Foreground="{DynamicResource ForegroundPrimary}"
                                    Command="{Binding SaveProjectCommand}" />
                        </StackPanel>
                    </Border>
                    </StackPanel>
            </ScrollViewer>
                                </Border>
                            </Border>
                        </Grid>
                    </UserControl>
